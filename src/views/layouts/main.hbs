<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tudo Saboroso 🥗</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    
    <style>
        .navbar-brand { font-weight: 700; color: #28a745 !important; }
        .bg-orange { background-color: #ff8c00; color: white; }
        .btn-orange { background-color: #ff8c00; color: white; border: none; }
        .btn-orange:hover { background-color: #e67e00; color: white; }
        .badge-custom { background-color: #28a745; color: white; padding: 2px 8px; border-radius: 10px; font-size: 0.8rem; }
    </style>
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand" href="/home">Tudo Saboroso 🥗</a>
            
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/home">Início</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/relatorio/habilidades">📊 Competências</a>
                    </li>
                    {{#if usuario}}
                    <li class="nav-item">
                        <a class="nav-link" href="/meu-perfil">Meu Perfil</a>
                    </li>
                    {{/if}}
                </ul>

                <ul class="navbar-nav ml-auto align-items-center">
                    {{#if usuario}}
                        {{#if usuario.isAdmin}}
                            <li class="nav-item">
                                <a class="nav-link text-secondary" href="/usuario">Gerenciar Alunos</a>
                            </li>
                        {{/if}}
                        
                        <li class="nav-item mx-3">
                            <span class="navbar-text text-dark">Olá, <strong>{{usuario.login}}</strong></span>
                        </li>
                        
                        <li class="nav-item">
                            <a class="btn btn-outline-danger btn-sm" href="/logout">Sair</a>
                        </li>
                    {{else}}
                        <li class="nav-item">
                            <a class="btn btn-success px-4" href="/login">Entrar</a>
                        </li>
                    {{/if}}
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        {{{body}}}
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>