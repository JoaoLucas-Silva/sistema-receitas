<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-transparent p-0">
        <li class="breadcrumb-item"><a href="/home" class="text-success">Início</a></li>
        <li class="breadcrumb-item active">{{receita.nome}}</li>
    </ol>
</nav>

<div class="bg-white border rounded-lg p-5 shadow-sm">
    <div class="row mb-4">
        <div class="col">
            <div class="mb-3">
                {{#each receita.categorias}}
                <span class="badge badge-success mr-2">{{this.nome}}</span>
                {{/each}}
            </div>
            <h1 class="font-weight-bold text-dark mb-2">{{receita.nome}}</h1>
            <p class="lead text-muted">{{receita.descricao}}</p>
        </div>
        {{#if receita.link}}
        <div class="col-auto">
            <a href="{{receita.link}}" target="_blank" class="btn btn-outline-dark font-weight-bold">
                Ver Referência Externa ↗
            </a>
        </div>
        {{/if}}
    </div>

    <hr class="my-5">

    <div class="row">
        <div class="col-md-5 border-right">
            <h5 class="text-uppercase text-muted small font-weight-bold mb-4 tracking-wider">Ingredientes</h5>
            <div class="text-dark" style="white-space: pre-line;">
                {{receita.ingredientes}}
            </div>
        </div>
        <div class="col-md-7 pl-md-5">
            <h5 class="text-uppercase text-muted small font-weight-bold mb-4 tracking-wider">Modo de Preparo</h5>
            <div class="text-dark leading-relaxed" style="white-space: pre-line;">
                {{receita.modoPreparo}}
            </div>
        </div>
    </div>

    <div class="mt-5 pt-4 border-top">
        <h6 class="font-weight-bold text-muted small text-uppercase mb-3">Responsáveis por esta receita:</h6>
        <div class="d-flex flex-wrap">
            {{#each receita.Usuarios}}
            <div class="bg-light px-3 py-2 rounded-pill mr-2 mb-2 small font-weight-bold border d-flex align-items-center">
                👤 {{this.login}} 
                
                {{#if this.ReceitaUsuario.criador}}
                    <span class="text-success ml-1">(Criador)</span>
                {{else}}
                    {{!-- Botão de remover coautor (só aparece se o usuário logado for autor) --}}
                    {{#if ../eAutor}}
                    <form action="/receita/{{../receita.id}}/coautor/{{this.id}}?_method=DELETE" method="POST" class="d-inline ml-2 mb-0">
                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Remover coautor" onclick="return confirm('Remover este colega da receita?')">✖</button>
                    </form>
                    {{/if}}
                {{/if}}
            </div>
            {{/each}}
        </div>
    </div>
</div>

{{!-- Painel do Autor: Gerenciar Receita e Coautores --}}
{{#if eAutor}}
<div class="mt-4 p-4 bg-light border rounded-lg shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="font-weight-bold mb-0 text-dark">Painel do Autor</h5>
        <div>
            <a href="/receita/editar/{{receita.id}}" class="btn btn-outline-primary btn-sm font-weight-bold px-3 mr-2">✏️ Editar Receita</a>
            <form action="/receita/{{receita.id}}?_method=DELETE" method="POST" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm font-weight-bold px-3" 
                    onclick="return confirm('Excluir esta receita definitivamente?')">🗑️ Remover Receita</button>
            </form>
        </div>
    </div>

    <hr>

    <div class="row align-items-end mt-3">
        <div class="col-md-6">
            <h6 class="font-weight-bold small text-uppercase mb-2">Adicionar Coautor</h6>
            <form action="/receita/{{receita.id}}/coautor" method="POST" class="d-flex">
                <select name="usuarioId" class="form-control form-control-sm mr-2" required>
                    <option value="" disabled selected>Selecione um colega...</option>
                    {{#each usuariosDisponiveis}}
                        <option value="{{this.id}}">{{this.login}}</option>
                    {{/each}}
                </select>
                <button type="submit" class="btn btn-success btn-sm font-weight-bold px-3">Adicionar</button>
            </form>
        </div>
    </div>
</div>
{{/if}}

<div class="mt-5 pt-5 border-top">
    <h4 class="font-weight-bold mb-4">Comentários</h4>

    {{#if usuario}}
    <div class="bg-light p-4 rounded-lg mb-5 border">
        <form action="/receita/{{receita.id}}/comentario" method="POST">
            <div class="form-group">
                <label class="small font-weight-bold text-muted text-uppercase">Sua opinião</label>
                <textarea name="texto" class="form-control border-0" rows="3" 
                    placeholder="Compartilhe o que achou desta receita..." required></textarea>
            </div>
            <div class="text-right">
                <button type="submit" class="btn btn-primary btn-sm px-4 shadow-sm">Publicar Comentário</button>
            </div>
        </form>
    </div>
    {{else}}
    <div class="alert alert-secondary text-center mb-5">
        <a href="/login" class="font-weight-bold">Faça login</a> para comentar nesta receita.
    </div>
    {{/if}}

    <div class="space-y-4">
        {{#each receita.comentarios}}
        <div class="bg-white border rounded-lg p-4 mb-3">
            <div class="d-flex justify-content-between mb-2">
                <span class="font-weight-bold text-dark text-sm">👤 {{this.usuarioLogin}}</span>
                <span class="text-muted small">{{formatDate this.createdAt}}</span>
            </div>
            <p class="text-muted mb-0 small">{{this.texto}}</p>
        </div>
        {{else}}
        <div class="text-center py-4">
            <p class="text-muted italic small">Nenhum comentário registrado nesta receita.</p>
        </div>
        {{/each}}
    </div>
</div>