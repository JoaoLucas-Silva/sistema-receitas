<div class="row justify-content-center py-5">
    <div class="col-md-4">
        <div class="text-center mb-4">
            <h2 class="font-weight-bold text-success">Tudo Saboroso 🥗</h2>
            <p class="text-muted small">Faça login para gerenciar suas receitas.</p>
        </div>
        <div class="bg-white border rounded-lg p-4 shadow-sm">
            <form action="/login" method="POST">
                <div class="form-group">
                    <label class="small font-weight-bold text-muted text-uppercase">Usuário</label>
                    <input type="text" name="login" class="form-control border-light bg-light" required>
                </div>
                <div class="form-group mb-4">
                    <label class="small font-weight-bold text-muted text-uppercase">Senha</label>
                    <input type="password" name="senha" class="form-control border-light bg-light" required>
                </div>
                <button type="submit" class="btn btn-primary btn-block py-2">Entrar no Sistema</button>
            </form>
        </div>
    </div>
</div>